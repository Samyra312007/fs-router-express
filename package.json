{
  "name": "fs-router-express",
  "version": "0.1.0",
  "description": "File-based routing engine for Express.js — zero-config, convention-driven API routing",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "express",
    "router",
    "file-based-routing",
    "filesystem-router",
    "fs-router",
    "auto-router",
    "api",
    "rest",
    "typescript",
    "zero-config"
  ],
  "license": "MIT",
  "author": {
    "name": "fs-router-express",
    "url": "https://github.com/anomalyco/fs-router-express"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/fs-router-express.git"
  },
  "bugs": {
    "url": "https://github.com/anomalyco/fs-router-express/issues"
  },
  "homepage": "https://github.com/anomalyco/fs-router-express#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {},
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "express": "^4.18.2",
    "supertest": "^6.3.4",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
